# ─────────────────────────────────────────────────────────────────────────────
# Elite Tenancy — Environment Variables
# Copy this file to .env.local (frontend) and .env (backend) and fill in values.
# NEVER commit .env files — they are in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend (artifacts/api-server/.env) ──────────────────────────────────────

# PostgreSQL connection string (from Render or local Docker)
DATABASE_URL=postgresql://user:password@host:5432/elite_tenancy

# Clerk — get from https://dashboard.clerk.com → API Keys
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google AI (Gemini 2.0 Flash) — get from https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CORS — comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=https://www.elitetenancy.co.uk,https://elitetenancy.co.uk

# Server port (Render sets this automatically; default 3000 locally)
PORT=3000

# Node environment
NODE_ENV=production


# ── Frontend (artifacts/elite-tenancy/.env.local) ────────────────────────────

# Clerk publishable key (same value as above — safe to expose in browser)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk proxy URL — your backend URL + /clerk-proxy
# (proxies Clerk requests through your domain for custom domain auth)
VITE_CLERK_PROXY_URL=https://api.elitetenancy.co.uk/clerk-proxy

# API base URL (your Render backend URL)
VITE_API_BASE_URL=https://api.elitetenancy.co.uk


# ── Stripe — REQUIRED for payments ──────────────────────────────────────────
# Get from https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs — create products in Stripe Dashboard, paste Price IDs here
STRIPE_PRICE_STANDARD=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PROFESSIONAL=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_MANAGED=price_xxxxxxxxxxxxxxxxxxxx

# Frontend (safe to expose in browser)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Wise (landlord payouts) — get from https://wise.com/business
# WISE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WISE_PROFILE_ID=xxxxxxxx

# PayPal (optional fallback) — get from https://developer.paypal.com
# PAYPAL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PAYPAL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_PAYPAL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional — Week 1 Revenue Features ───────────────────────────────────────

# UploadThing (property photo uploads) — get from https://uploadthing.com
# UPLOADTHING_SECRET=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# UPLOADTHING_APP_ID=xxxxxxxxxxxxxxxxxxxx

# Resend (transactional email) — get from https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=hello@elitetenancy.co.uk

# Sentry (error monitoring) — get from https://sentry.io
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxxx
# VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxxx
