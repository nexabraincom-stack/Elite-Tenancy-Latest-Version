{
  "buildCommand": "BASE_PATH=/ PORT=3000 pnpm build && node scripts/seo-prerender.mjs",
  "outputDirectory": "dist/public",
  "installCommand": "npx pnpm@9 install --no-frozen-lockfile",
  "framework": null,
  "redirects": [
    {
      "source": "/%20:rest*",
      "destination": "https://www.elitetenancy.co.uk/",
      "statusCode": 308
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "elitetenancy.co.uk" }],
      "destination": "https://www.elitetenancy.co.uk/$1",
      "statusCode": 308
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "elitetenancy.uk" }],
      "destination": "https://www.elitetenancy.co.uk/$1",
      "statusCode": 308
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.elitetenancy.uk" }],
      "destination": "https://www.elitetenancy.co.uk/$1",
      "statusCode": 308
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "elitetenancy.com" }],
      "destination": "https://www.elitetenancy.co.uk/$1",
      "statusCode": 308
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.elitetenancy.com" }],
      "destination": "https://www.elitetenancy.co.uk/$1",
      "statusCode": 308
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://elite-tenancy-latest-version-api-se-rho.vercel.app/api/:path*"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
