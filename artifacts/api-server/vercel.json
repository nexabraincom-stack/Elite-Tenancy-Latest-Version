{
  "installCommand": "cd ../.. && npx pnpm@9.15.9 install --no-frozen-lockfile --ignore-scripts=false",
  "buildCommand": "node build-vercel.mjs",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    { "path": "/api/rtr/run-reminders",              "schedule": "0 9 * * *" },
    { "path": "/api/launch-discount/run-daily",       "schedule": "0 6 * * *" },
    { "path": "/api/reviews/run-daily",               "schedule": "0 10 * * *" },
    { "path": "/api/reviews/run-followup",            "schedule": "30 10 * * *" },
    { "path": "/api/automations/run-follow-ups",      "schedule": "0 8 * * *" },
    { "path": "/api/viewings/run-reminders",          "schedule": "15 8 * * *" }
  ],
  "regions": ["lhr1"]
}
